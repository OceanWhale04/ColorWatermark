<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/25.0.2 Chrome/128.0.6613.186 Electron/32.2.5 Safari/537.36" version="25.0.2">
  <diagram id="fig5-7" name="图5-7 CLAHE增强流程图">
    <mxGraphModel dx="1207" dy="880" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="T0" value="图5-7 CLAHE 增强流程图（与 Preprocessor::clahe 一致）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="140" y="20" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="S" value="开始：输入图像 I&#xa;（BGR 彩色 或 单通道灰度）&#xa;参数：clipLimit，tileSize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="255" y="100" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="D" value="通道数 == 1 ？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="270" y="180" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="Y1" value="createCLAHE(clipLimit, tileSize)&#xa;直接对整幅图 apply" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="520" y="180" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="N1" value="cvtColor(I, Lab, COLOR_BGR2Lab)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="220" y="280" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="N2" value="split(Lab) → L, a, b 三通道" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="220" y="330" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="N3" value="仅对 L 通道：&#xa;createCLAHE(clipLimit, tileSize)→apply(L)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="220" y="380" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="N4" value="merge(L,a,b) → Lab" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="220" y="450" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="N5" value="cvtColor(Lab, Out, COLOR_Lab2BGR)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="220" y="500" width="260" height="44" as="geometry" />
        </mxCell>
        <mxCell id="E" value="结束：输出增强图像 Out&#xa;（OpenCV Lab 中 L∈[0,255] 与实现一致）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="220" y="559.5" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" parent="1" source="S" target="D" edge="1">
