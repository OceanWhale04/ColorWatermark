        </mxCell>
        <mxCell id="EST" value="每块：estimate = (σ_det − σ_orig) / α（公式4-2，标量最大奇异值）&lt;br&gt;三通道累加到 voteAccum[idx]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=center;spacingLeft=8;" parent="1" vertex="1">
