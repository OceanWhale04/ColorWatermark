        </mxCell>
        <mxCell id="VOT" value="voteAccum /= 3（三通道算术平均，非多数投票）&lt;br&gt;零阈值：estimate_avg ≥ 0 → 二值 255，否则 0&lt;br&gt;（双极性解码；与「&amp;gt;0.5」不同）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;spacingLeft=8;" parent="1" vertex="1">
