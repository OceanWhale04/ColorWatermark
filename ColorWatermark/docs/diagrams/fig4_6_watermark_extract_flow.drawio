        </mxCell>
        <mxCell id="CH" value="每通道：DWT→LL → 8×8 DCT-SVD → 每块最大奇异值矩阵&lt;br&gt;σ_det（来自 I&#39;_proc）、σ_orig（来自 I_orig_proc）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;spacingLeft=8;" parent="1" vertex="1">
