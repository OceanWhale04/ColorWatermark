<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/25.0.2 Chrome/128.0.6613.186 Electron/32.2.5 Safari/537.36" version="25.0.2">
  <diagram id="fig2-2" name="图2-2 二维DWT一层分解">
    <mxGraphModel dx="1207" dy="880" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="T0" value="图2-2 二维一层 DWT 分解示意图（Haar，四子带）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="180" y="20" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IN" value="输入：单通道图像 I&#xa;尺寸 H × W&#xa;（H、W 均为偶数）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="80" y="170" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ARR" value="一层可分离二维 Haar DWT" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=12;exitX=1.006;exitY=0.138;exitDx=0;exitDy=0;exitPerimeter=0;" parent="1" edge="1" source="IN">
          <mxGeometry x="-1" y="58" width="50" height="50" relative="1" as="geometry">
            <mxPoint x="250" y="120" as="sourcePoint" />
            <mxPoint x="310" y="120" as="targetPoint" />
            <mxPoint x="-8" y="7" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="BOX" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;dashed=0;" parent="1" vertex="1">
          <mxGeometry x="320" y="70" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="LL" value="LL&#xa;低频近似&#xa;（主要能量）&#xa;H/2 × W/2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="330" y="80" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="HL" value="HL&#xa;水平方向细节&#xa;H/2 × W/2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="500" y="80" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="LH" value="LH&#xa;垂直方向细节&#xa;H/2 × W/2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="330" y="180" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="HH" value="HH&#xa;对角细节&#xa;H/2 × W/2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="500" y="180" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="LBL" value="四子带拼接后总尺寸仍为 H×W（子带各占 1/4 像素）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="320" y="285" width="380" height="24" as="geometry" />
        </mxCell>
        <mxCell id="F1" value="一维 Haar 分析（每个方向对相邻样本做低通 / 高通，再二抽取）&#xa;低通：h₀ = [½, ½] 或正交归一写法 [1/√2, 1/√2]&#xa;高通：h₁ = [½, −½] 或 [1/√2, −1/√2]&#xa;二者仅差常数因子，均能实现完美重构（须与综合滤波器配套）" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="80" y="330" width="600" height="90" as="geometry" />
        </mxCell>
        <mxCell id="F2" value="本工程实现（dwt2）：先沿「列对」做 1-D Haar（宽减半），再沿「行对」做 1-D Haar（高减半），得到 LL、LH、HL、HH；idwt2 为逆序可逆运算。" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="80" y="430" width="600" height="70" as="geometry" />
        </mxCell>
        <mxCell id="F3" value="注：OpenCV 与常见教材对 LH/HL 命名可能互换；本文与代码中子带含义以「先列后行」两步高频所在位置为准，或与 Mallat 图示对照时留意行列顺序。" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2" parent="1" vertex="1">
          <mxGeometry x="80" y="510" width="620" height="44" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
