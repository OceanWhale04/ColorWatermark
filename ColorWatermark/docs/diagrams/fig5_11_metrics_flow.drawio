        <mxCell id="es1" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" parent="1" source="S1" target="S1a" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es2" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" parent="1" source="S1a" target="S1b" edge="1">
