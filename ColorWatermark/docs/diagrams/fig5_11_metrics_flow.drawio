        <mxCell id="e2" value="SSIM" style="endArrow=block;html=1;rounded=0;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="D" target="S1" edge="1">
          <mxGeometry relative="1" as="geometry" />
