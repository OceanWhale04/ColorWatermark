<mxfile host="app.diagrams.net" modified="2026-04-30T18:00:00.000Z" agent="ColorWatermark-docs" version="22.1.0" type="device">
  <diagram id="fig5-9" name="图5-9 维纳滤波频域流程">
    <mxGraphModel dx="1000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="T0" value="图5-9 维纳滤波处理流程图（含频域步骤，与 Preprocessor::wiener 一致）" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="560" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="S" value="开始：运动模糊图 B（BGR，8U）&#xa;已知 PSF 核 h（与退化一致，已归一化）&#xa;维纳常数 K（如 0.01）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="P0" value="split(B) → B,G,R 三通道&#xa;（assert 三通道彩色）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="220" y="160" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="P1" value="对每一通道循环（以下步骤各执行一次）" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="200" y="230" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="F0" value="通道矩阵转 CV_32F" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="240" y="300" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="F1" value="按 getOptimalDFTSize 对图像与 PSF 零填充至相同频域尺寸&#xa;（图像 reflect 边界，PSF constant 补零）" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="355" width="480" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="F2" value="DFT：G = DFT(填充后通道)&#xa;H = DFT(填充后 PSF)&#xa;（输出为双通道复数 CV_32FC2）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="160" y="430" width="400" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="F3" value="频域维纳核心（逐频率 bin 矢量化）&#xa;分子：num = G · conj(H)  （OpenCV：mulSpectrums(G,H,0,true)）&#xa;分母：denom = |H|² + K = Re(H)² + Im(H)² + K&#xa;F = num / denom（对复数实部、虚部分别除以 denom）" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="100" y="515" width="520" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="F4" value="IDFT：空域估计（DFT_REAL_OUTPUT | DFT_SCALE）&#xa;裁剪至原图尺寸 → 转 CV_8U，压入该通道结果" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="160" y="630" width="400" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="Dch" value="三通道&#xa;均已处理？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="260" y="710" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="E" value="merge(B,G,R) → 输出复原 BGR 图像" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="220" y="840" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="NOTE" value="说明：PSF 由 generateMotionPSF(size, angle, length) 生成；与 Utils::simulateMotionBlur 使用同一几何参数时构成「已知 PSF」理想设定。" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="60" y="910" width="600" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="e0" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="S" target="P0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="P0" target="P1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="P1" target="F0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="F0" target="F1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="F1" target="F2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="F2" target="F3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="F3" target="F4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="F4" target="Dch">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="是" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Dch" target="E">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="loop" value="否，下一通道" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;dashed=1;fontSize=10;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="Dch" target="F0">
